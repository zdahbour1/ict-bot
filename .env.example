# Copy this file to .env and fill in your real values
# Never share or commit your .env file

TASTYTRADE_USERNAME=your_tastytrade_email@example.com
TASTYTRADE_PASSWORD=your_tastytrade_password
TASTYTRADE_ACCOUNT=your_account_number
PAPER_TRADING=true
WEBHOOK_SECRET=ict-secret-token

# Interactive Brokers (set USE_IB=true to use IB as your broker)
USE_IB=false
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1
IB_ACCOUNT=
